# Book Marketplace Environment Configuration
# Copy this file to .env and update with your values

# Server Configuration
PORT=3001
NODE_ENV=development

# Set to true to expose full error messages in API responses (local dev only).
# Staging deployments should NOT set this — they will return generic errors like production.
# EXPOSE_ERRORS=true

# Security (REQUIRED - Generate your own!)
SESSION_SECRET=change-this-to-a-random-string-at-least-32-chars
ADMIN_PASSWORD_HASH=generate-with-bcrypt-or-use-setup-script

# Branding
MARKETPLACE_NAME=My Bookstore
MARKETPLACE_TAGLINE=Digital books delivered instantly
SUPPORT_EMAIL=support@yourdomain.com

# Email Configuration (Optional)
EMAIL_ENABLED=true
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Stripe Configuration (Required for payments)
STRIPE_ENABLED=true
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_SECRET_KEY=sk_test_your_key_here

# ─── AI Store Builder ────────────────────────────────────────────────────────
# Required for the AI Store Builder (POST /api/store-builder/generate).
# Without this, the endpoint returns a 500 with a clear error message.
# Get yours at: https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-...

# ─── AI Features (optional but recommended) ──────────────────────────────────
# Required for semantic search in AI Discovery Engine. Without this, falls back to
# keyword search — the README's "revolutionary semantic search" claim won't hold.
# Also used by AI Page Builder (gpt-4o-mini) and AI Discovery embeddings.
# Get yours at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# Database runtime
# If DATABASE_URL or SUPABASE_DB_URL is set, backend uses Postgres/Supabase.
# Otherwise it falls back to SQLite DATABASE_PATH.
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
# SUPABASE_DB_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
DATABASE_TYPE=sqlite
DATABASE_PATH=./database/marketplace.db

# File Upload Settings
MAX_FILE_SIZE_MB=50
ALLOWED_FILE_TYPES=.pdf,.epub

# Features (all optional)
ENABLE_PREVIEWS=true
ENABLE_ANALYTICS=false
ENABLE_FEDERATION=false

# Federation Network (if enabled)
FEDERATION_API_KEY=request-from-network
FEDERATION_STORE_ID=your-store-id

# Blockchain & NFT Configuration (Optional - for Proof of Read NFTs)
BLOCKCHAIN_NETWORK=polygon
# Options: polygon, ethereum, localhost

# Contract Addresses (after deployment)
BOOK_OWNERSHIP_CONTRACT_ADDRESS=
BADGES_CONTRACT_ADDRESS=
INHERITANCE_CONTRACT_ADDRESS=

# Blockchain RPC URLs
POLYGON_RPC_URL=https://polygon-rpc.com
ETHEREUM_RPC_URL=https://eth.llamarpc.com

# Private key for minting (NEVER commit this to Git!)
# PRIVATE_KEY=your-private-key-here

# ─── IPFS / NFT Features ─────────────────────────────────────────────────────
# Required for IPFS book pinning (Proof of Read NFTs, censorship-resistant delivery).
# Auto-pinning fires on every completed purchase when PINATA_JWT is set.
# Get yours at: https://app.pinata.cloud/keys
# PINATA_JWT=eyJ...
PINATA_API_KEY=
PINATA_SECRET_KEY=
PINATA_JWT=

# Marketplace URL (for NFT metadata)
MARKETPLACE_URL=https://yourdomain.com

# ─── Storefront API (external server-to-server access) ──────────────────────
# Shared secret for POST requests to /api/storefront/checkout from external systems (e.g. ArxMint).
# When set, callers must include this value in the X-Api-Key request header.
# Leave unset in local development to allow unauthenticated access.
# STOREFRONT_API_KEY=generate-a-random-secret-here

# ─── ArxMint payment network (optional) ─────────────────────────────────────
# Enables L402 paywalls, Cashu ecash micropayments, and Lightning-native access.
# Run the ArxMint SDK locally or point to a hosted instance.
# Reference implementation: C:\code\arxmint (local project)
# ARXMINT_API_URL=http://localhost:3002

# ─── Printful POD fulfillment (optional) ────────────────────────────────────
# Enables physical dropship fulfillment for products marked:
#   fulfillment: "pod", podProvider: "printful", podVariantId: <sync_variant_id>
#
# PRINTFUL_API_KEY=your-printful-private-api-token
# PRINTFUL_STORE_ID=your-printful-store-id
# PRINTFUL_WEBHOOK_SECRET=shared-secret-with-printful-webhook-config
# PRINTFUL_API_BASE=https://api.printful.com

# ─── Lulu POD fulfillment (optional) ────────────────────────────────────────
# Enables physical book dropshipping for products marked:
#   fulfillment: "pod", podProvider: "lulu"
#
# LULU_CLIENT_KEY=your-lulu-client-id
# LULU_CLIENT_SECRET=your-lulu-client-secret
# LULU_API_URL=https://api.sandbox.lulu.com
# LULU_WEBHOOK_SECRET=shared-secret-with-lulu-webhook-config
